# Copy to .env to override docker-compose defaults: cp .env.example .env

# --- database ---
POSTGRES_USER=ct
POSTGRES_PASSWORD=ct
POSTGRES_DB=controltower

# --- agent lifecycle ---
# simulated = deterministic stub executor (default; no Claude needed).
# real = drives the agentic CLI (claude -p) — needs the CLI + auth available to the api
#        container, which the default image does NOT ship. Advanced/local use only.
ASV3_AGENT_MODE=simulated

# memory = in-process lifecycle checkpointer (default, robust).
# postgres = durable across restarts (uses the Postgres DB).
ASV3_CHECKPOINTER=memory

# Leave empty for offline DeterministicEmbeddings + in-process vector store (default).
# Set to "huggingface" for real sentence-transformer embeddings persisted in pgvector
# (pulls torch + downloads a model on first use — a much larger image/footprint).
ASV3_EMBEDDINGS=
