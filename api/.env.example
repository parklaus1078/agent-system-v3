# api/.env — backend config for running the api ON THE HOST.
# Copy to api/.env and edit:   cp api/.env.example api/.env
# Loaded automatically on startup (app/__init__.py). Real env vars / docker-compose still
# override these, so `api/.env` is just the convenient default for `uvicorn app.main:app`.
# (api/.env is gitignored; this .example is committed.)

# --- storage ---
# SQLite (default, zero-setup, persistent file):
DATABASE_URL=sqlite+pysqlite:///./dev.db
# Postgres + pgvector (e.g. via `docker compose -f docker-compose.db.yml up -d`):
# DATABASE_URL=postgresql+psycopg://ct:ct@localhost:5432/controltower

# --- agent mode ---
# simulated = deterministic stub, no quota/keys (default). real = `claude -p` CLI.
ASV3_AGENT_MODE=simulated
# real mode only: which CLI the executor drives (claude | codex)
# ASV3_BRAIN=claude

# --- execution concurrency ---
# 1 (default) = run step execution in a background thread so approve/review return at once
# and the UI tracks progress live (ticket data.activity, polled). 0 = synchronous (in-request).
ASV3_ASYNC_EXEC=1

# --- target repos (where the executor commits each step) ---
# Each PROJECT builds in its OWN repo at  ${ASV3_WORKSPACE_DIR}/{project_id}
# (auto-created + git-init'd on first run). Defaults to <api>/.asv3-workspace if unset.
ASV3_WORKSPACE_DIR=/tmp/asv3-workspace
# ASV3_TARGET_REPO_DIR is a deprecated ALIAS of ASV3_WORKSPACE_DIR (also a per-project root,
# {path}/{project_id}); used ONLY when ASV3_WORKSPACE_DIR is unset:
# ASV3_TARGET_REPO_DIR=/tmp/asv3-target
# Per-project override: set the Objective node's data.repo_dir (highest precedence).

# --- LangGraph checkpointer: memory | postgres | auto (postgres iff DATABASE_URL is postgres) ---
ASV3_CHECKPOINTER=auto

# --- RAG embeddings: unset = deterministic offline; huggingface = real model (+[rag] extra) ---
# ASV3_EMBEDDINGS=huggingface

# --- wiki promotion target (unset = promotion skipped, nothing written to disk) ---
# ASV3_LLM_WIKI_ROOT=/home/you/llm_wiki
